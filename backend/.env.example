# 后端环境变量配置示例

# 服务器配置
PORT=5000
NODE_ENV=development

# MongoDB
# 本地开发: mongodb://localhost:27017/essay_grader
# 生产环境: mongodb+srv://username:password@cluster.mongodb.net/essay_grader
MONGODB_URI=mongodb://localhost:27017/essay_grader

# JWT 密钥（生产环境请使用强密钥，至少 32 位）
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# 智谱AI API 密钥
# 获取地址: https://open.bigmodel.cn
ZHIPU_API_KEY=your_zhipu_api_key

# DeepSeek API 密钥
# 获取地址: https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
